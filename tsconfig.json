{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["DOM", "ES2022"],
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
